# Variables d'environnement de l'API en production (à renseigner dans Render →
# Environment). NE JAMAIS committer les vraies valeurs.

NODE_ENV=production
# PORT : injecté par Render, ne pas le fixer ici.

# Postgres MANAGÉ (Neon / Supabase / RDS...). DB_SSL=true obligatoire chez ces providers.
DB_HOST=
DB_PORT=5432
DB_USERNAME=
DB_PASSWORD=
DB_NAME=
DB_SSL=true

# Secrets JWT — générer : openssl rand -base64 48
JWT_ACCESS_SECRET=
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_SECRET=
JWT_REFRESH_EXPIRES_IN=7d

THROTTLE_TTL=60000
THROTTLE_LIMIT=100

# CORS : inutile ici (le navigateur ne tape pas l'API en direct), laisser vide.
CORS_ORIGINS=
