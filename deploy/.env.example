# Variables de niveau compose (lues par docker-compose.prod.yml).
# Copier en .env sur le serveur.

# Domaine public du front (TLS auto via Caddy). Doit pointer (DNS A/AAAA) vers le serveur.
DOMAIN=prepalist.exemple.com

# Tag d'image à déployer (défaut: latest). Mettre la version taguée pour figer, ex. 0.1.0
TAG=latest
