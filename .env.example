NODE_ENV=local
PORT=3000

# Database (aligné sur docker-compose.yml)
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=prepalist
DB_PASSWORD=prepalist
DB_NAME=prepalist

# Auth — secrets à régénérer, ne jamais committer les vraies valeurs
JWT_ACCESS_SECRET=change-me-access-secret
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_SECRET=change-me-refresh-secret
JWT_REFRESH_EXPIRES_IN=7d

# Throttler
THROTTLE_TTL=60000
THROTTLE_LIMIT=100

# IA (Phase 4) — clé back uniquement, jamais exposée au front
ANTHROPIC_API_KEY=
